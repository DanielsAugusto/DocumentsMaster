# ===========================================
# DocumentsMaster - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com credenciais reais!

# Supabase
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# ===== Edge Function (google-drive-proxy) =====
# Essas variáveis são configuradas no Supabase Dashboard > Edge Functions > Secrets
# Não são usadas diretamente pelo frontend.
#
# GOOGLE_DRIVE_API_KEY=sua-api-key-do-google
# GOOGLE_SERVICE_ACCOUNT_EMAIL=nome@projeto.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
#
# CORS — Domínios permitidos (separados por vírgula)
# Se não definido, aceita o Supabase + localhost por padrão.
# Em produção, adicione seu domínio real:
# ALLOWED_ORIGINS=https://yaixcnbkubdcbitywuhc.supabase.co,https://meusite.com.br
